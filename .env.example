# cs-server 환경변수 예시 — 복사해서 .env 로 사용하세요.
#   cp .env.example .env  후 값 채우기
# (.env 는 .gitignore 로 커밋되지 않습니다)

# MySQL 접속 URL (로컬 예: root, 비밀번호 없음, 새 DB명 cs_system)
DATABASE_URL="mysql://root@127.0.0.1:3306/cs_system?charset=utf8mb4"

# 모든 /api/* 요청에 필요한 API 키 (프론트의 VITE_API_KEY 와 동일해야 함)
API_KEY="cs-dev-api-key"

# JWT 서명 시크릿
JWT_SECRET="change-me-to-a-long-random-secret"

# Resend 이메일 API 키 (비밀번호 재설정 메일 발송용) — https://resend.com
MAIL_KEY="re_your_resend_api_key"
