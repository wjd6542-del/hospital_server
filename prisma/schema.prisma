generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////////////
// 로그 / 알림 enum
//////////////////////////////////////////////////////////////

enum LogAction {
  CREATE
  UPDATE
  DELETE
  UPSERT
  CREATEMANY
  UPSERTMANY
  DELETEMANY
  VIEW
  LOGIN
  LOGOUT
}

enum LogStatus {
  SUCCESS
  FAIL
}

enum NotificationType {
  SYSTEM
}

//////////////////////////////////////////////////////////////
// 권한 / 사용자
//////////////////////////////////////////////////////////////

/// 사용자 역할 (관리자, 일반 사용자 등)
model Role {
  id          Int     @id @default(autoincrement())
  name        String  @unique // 역할 이름 (고유)
  description String? // 역할 설명
  is_super    Boolean @default(false) // 슈퍼 관리자 여부
  is_active   Boolean @default(true) // 활성화 여부 (false 면 기본 리스트에서 제외)
  sort        Int     @default(0) // 정렬 순서

  users User[]

  created_at  DateTime         @default(now())
  permissions RolePermission[]
}

/// 시스템 사용자
model User {
  id Int @id @default(autoincrement())

  username String @unique @db.VarChar(100) // 로그인 아이디 (고유)
  password String @db.VarChar(255) // 해시된 비밀번호

  name  String  @db.VarChar(100) // 실명
  email String? @db.VarChar(200) // 이메일
  code  String? @db.VarChar(15) // 사번 또는 식별 코드

  role_id Int
  role    Role @relation(fields: [role_id], references: [id]) // 역할 참조

  is_active   Boolean @default(true) // 계정 활성화 여부
  ip_restrict Boolean @default(false) // IP 제한 사용 여부 (true면 화이트리스트만 접근 가능)

  last_login DateTime? // 마지막 로그인 일시

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  logs             AuditLog[]
  notifications    Notification[]
  userIpWhitelists UserIpWhitelist[]
  posts            Post[]
  postComments     PostComment[]
  employee_id      Int?              @unique
  employee         Employee?         @relation("UserEmployee", fields: [employee_id], references: [id])
}

/// 권한 항목 (기능 단위 접근 제어)
model Permission {
  id        Int              @id @default(autoincrement())
  code      String           @unique // 권한 코드 (예: material.read, inbound.create)
  name      String // 권한 표시명
  group     String // UI 그룹 (예: 품목관리, 입고관리)
  action    String           @default("") // HTTP 메서드 또는 액션 유형
  is_active Boolean          @default(true) // 활성화 여부
  sort      Int              @default(0)
  roles     RolePermission[]
}

/// 역할-권한 매핑 (다대다 중간 테이블)
model RolePermission {
  id            Int        @id @default(autoincrement())
  role_id       Int
  permission_id Int
  role          Role       @relation(fields: [role_id], references: [id])
  permission    Permission @relation(fields: [permission_id], references: [id])

  @@unique([role_id, permission_id]) // 동일 역할에 동일 권한 중복 불가
}

/// 사용자 IP 화이트리스트 (ip_restrict=true인 사용자에게 적용)
model UserIpWhitelist {
  id        Int     @id @default(autoincrement())
  user_id   Int
  ip        String // 허용 IP (IPv4 / IPv6)
  memo      String? // 메모 (예: 회사 VPN, 재택 IP)
  is_active Boolean @default(true) // 활성화 여부

  user User @relation(fields: [user_id], references: [id])

  created_at DateTime @default(now())

  @@unique([user_id, ip]) // 동일 사용자에 동일 IP 중복 불가
  @@index([user_id])
}

/// 시스템 감사 로그 (누가 언제 무엇을 했는지 추적)
model AuditLog {
  id Int @id @default(autoincrement())

  user_id Int?
  user    User? @relation(fields: [user_id], references: [id]) // 행위 주체 (미로그인 시 null)

  page   String // 액션이 발생한 페이지/모듈
  action LogAction // 수행한 액션 유형

  target_type String? // 대상 모델명 (예: Material)
  target_id   Int? // 대상 레코드 ID

  description String? @db.Text // 액션 설명

  before_data Json? // 변경 전 데이터 스냅샷
  after_data  Json? // 변경 후 데이터 스냅샷

  ip         String? // 클라이언트 IP
  user_agent String? // 브라우저/클라이언트 정보

  status LogStatus @default(SUCCESS) // 처리 결과

  created_at DateTime @default(now())

  @@index([user_id])
}

/// 사용자 알림
model Notification {
  id Int @id @default(autoincrement())

  user_id     Int?
  user        User?            @relation(fields: [user_id], references: [id])
  type        NotificationType // 알림 유형
  title       String? // 알림 제목
  message     String? // 알림 본문
  action      String? // 클릭 시 이동할 경로
  target_type String? // 연관 대상 모델명
  target_id   Int? // 연관 대상 레코드 ID

  is_read    Boolean   @default(false) // 읽음 여부
  read_at    DateTime? // 읽은 일시
  created_at DateTime  @default(now())

  @@index([user_id])
  @@index([is_read])
}

//////////////////////////////////////////////////////////////
// 설정
//////////////////////////////////////////////////////////////

/// 시스템 설정 (키-값 형태의 동적 설정 관리)
model Settings {
  id Int @id @default(autoincrement())

  key  String @db.VarChar(100) // 설정 키 (예: company_name)
  text String @db.VarChar(255) // 설정 표시명 (UI용 레이블)

  value String @db.Text // 설정 값

  is_active Boolean @default(true) // 활성화 여부

  sort Int @default(0) // 정렬 순서

  created_at DateTime? @default(now())
  updated_at DateTime? @updatedAt

  @@index([sort])
}

/// 공통 코드 (직급·직종·고용형태·면허종류·부서유형 등)
model Category {
  id Int @id @default(autoincrement())

  group String @db.VarChar(50) // 코드 그룹 (department_type, position, job_type, employment_type, license_type)
  text  String @db.VarChar(255) // 표시명
  value String @db.VarChar(255) // 코드값

  is_active Boolean @default(true)
  sort      Int     @default(0)

  created_at DateTime? @default(now())
  updated_at DateTime? @updatedAt

  departmentTypes     Department[]      @relation("DepartmentType")
  employeePositions   Employee[]        @relation("EmployeePosition")
  employeeJobTypes    Employee[]        @relation("EmployeeJobType")
  employeeEmployTypes Employee[]        @relation("EmployeeEmploymentType")
  licenses            EmployeeLicense[] @relation("LicenseType")

  @@unique([group, value])
  @@index([group, sort])
}

/// 자주 하는 질문 (FAQ)
model Faq {
  id            Int     @id @default(autoincrement())
  category      String? // 분류 (FaqCategory.name 참조 문자열)
  question      String // 질문 제목
  question_body String? @db.LongText // 질문 내용(HTML)
  answer        String  @db.LongText
  sort          Int     @default(0)
  is_pinned     Boolean @default(false) // 상단 고정
  is_active     Boolean @default(true)
  view_count    Int     @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tags Tag[]

  @@index([category])
  @@index([sort])
}

/// FAQ 분류 (환경설정에서 관리)
model FaqCategory {
  id         Int      @id @default(autoincrement())
  name       String   @unique // 분류명
  sort       Int      @default(0)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([sort])
}

/// 태그 (FAQ 다중 태그, 환경설정에서 관리)
model Tag {
  id         Int      @id @default(autoincrement())
  name       String   @unique // 태그명
  color      String   @default("#64748b") // 칩 색상(hex)
  sort       Int      @default(0)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  faqs Faq[]

  @@index([sort])
}

//////////////////////////////////////////////////////////////
// 게시판 (board)
//////////////////////////////////////////////////////////////

/// 게시판 접근 레벨: ALL=전체, MEMBER=로그인 회원, ADMIN=관리자
enum BoardPermLevel {
  ALL
  MEMBER
  ADMIN
}

/// 게시판 (타입/권한/기능 토글로 다양하게 운용)
model Board {
  id          Int     @id @default(autoincrement())
  name        String // 게시판명
  slug        String  @unique // URL 식별자
  description String? // 설명

  read_level    BoardPermLevel @default(ALL) // 읽기 권한
  write_level   BoardPermLevel @default(MEMBER) // 쓰기 권한
  allow_comment Boolean        @default(true) // 댓글 허용
  allow_upload  Boolean        @default(true) // 파일/이미지 첨부 허용

  sort      Int     @default(0)
  is_active Boolean @default(true)

  created_at DateTime @default(now())

  posts Post[]

  @@index([sort])
}

/// 게시글
model Post {
  id       Int   @id @default(autoincrement())
  board_id Int
  board    Board @relation(fields: [board_id], references: [id])

  user_id Int?
  user    User? @relation(fields: [user_id], references: [id])

  title      String
  content    String  @db.LongText // HTML 본문
  is_notice  Boolean @default(false) // 공지 고정
  view_count Int     @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  comments    PostComment[]
  attachments PostAttachment[]

  @@index([board_id])
  @@index([is_notice])
  @@index([created_at])
}

/// 댓글
model PostComment {
  id      Int  @id @default(autoincrement())
  post_id Int
  post    Post @relation(fields: [post_id], references: [id], onDelete: Cascade)

  user_id Int?
  user    User? @relation(fields: [user_id], references: [id])

  content    String   @db.Text
  created_at DateTime @default(now())

  @@index([post_id])
}

/// 게시글 첨부 (이미지/파일)
model PostAttachment {
  id      Int  @id @default(autoincrement())
  post_id Int
  post    Post @relation(fields: [post_id], references: [id], onDelete: Cascade)

  path      String // /uploads/board/xxx
  filename  String // 원본 파일명
  mime_type String?
  size      Int?
  is_image  Boolean @default(false)

  created_at DateTime @default(now())

  @@index([post_id])
}

/// 다국어 번역팩 — name = { ko, en, ja, zh }. 한국어 텍스트를 키로 사용
model LangPack {
  id         Int      @id @default(autoincrement())
  name       Json // { ko, en, ja, zh }
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([is_active])
}

//////////////////////////////////////////////////////////////
// 인사 마스터 (부서 · 직원)
//////////////////////////////////////////////////////////////

/// 부서 (계층 트리)
model Department {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(100)
  code String @unique @db.VarChar(30) // 부서 코드 (예: DEPT-CARD)

  parent_id Int?
  parent    Department?  @relation("DepartmentTree", fields: [parent_id], references: [id])
  children  Department[] @relation("DepartmentTree")

  type_id Int? // 부서 유형 (Category: department_type)
  type    Category? @relation("DepartmentType", fields: [type_id], references: [id])

  // 부서장 — Employee.department_id 와 순환. 둘 다 nullable 로 둬서 풀린다.
  head_employee_id Int?
  head_employee    Employee? @relation("DepartmentHead", fields: [head_employee_id], references: [id])

  employees Employee[] @relation("EmployeeDepartment")

  financeTransactions FinanceTransaction[] @relation("FinanceTxnDepartment")
  purchaseOrders      PurchaseOrder[]      @relation("PODepartment")
  stockMovements      StockMovement[]      @relation("StockMoveDepartment")
  assets              Asset[]              @relation("AssetDepartment")
  facilityRequests    FacilityRequest[]    @relation("FacilityDepartment")
  appointments        Appointment[]        @relation("AppointmentDept")

  sort       Int      @default(0)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([parent_id])
  @@index([sort])
}

/// 직원 마스터 — 로그인 계정(User)과 분리, 선택적 1:1 연결
model Employee {
  id      Int     @id @default(autoincrement())
  emp_no  String  @unique @db.VarChar(30) // 사번
  name    String  @db.VarChar(100)
  name_en String? @db.VarChar(100)

  department_id Int?
  department    Department? @relation("EmployeeDepartment", fields: [department_id], references: [id])

  position_id        Int? // 직급 (Category: position)
  position           Category? @relation("EmployeePosition", fields: [position_id], references: [id])
  job_type_id        Int? // 직종 (Category: job_type)
  job_type           Category? @relation("EmployeeJobType", fields: [job_type_id], references: [id])
  employment_type_id Int? // 고용형태 (Category: employment_type)
  employment_type    Category? @relation("EmployeeEmploymentType", fields: [employment_type_id], references: [id])

  phone String? @db.VarChar(30)
  email String? @db.VarChar(200)

  hired_at    DateTime  @db.Date
  resigned_at DateTime? @db.Date // 있으면 퇴사자

  licenses       EmployeeLicense[]
  schedules      ShiftSchedule[]
  attendances    Attendance[]
  leaveGrants    LeaveGrant[]
  leaveRequests  LeaveRequest[]
  approvedLeaves LeaveRequest[]    @relation("LeaveApprover") // 이 직원이 승인/반려한 신청
  appointments   Appointment[]     @relation("AppointmentDoctor")
  headOfDepts    Department[]      @relation("DepartmentHead")
  user           User?             @relation("UserEmployee")

  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([department_id])
  @@index([name])
}

/// 직원 면허 (1직원 : N면허)
model EmployeeLicense {
  id          Int      @id @default(autoincrement())
  employee_id Int
  employee    Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  license_type_id Int // 면허 종류 (Category: license_type)
  license_type    Category @relation("LicenseType", fields: [license_type_id], references: [id])

  license_no String    @db.VarChar(60)
  issued_at  DateTime? @db.Date
  expires_at DateTime? @db.Date

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([employee_id])
}

//////////////////////////////////////////////////////////////
// 근태 · 교대
//////////////////////////////////////////////////////////////

/// 근태 상태 — 판정 우선순위: ABSENT > LATE > EARLY_LEAVE > NORMAL
enum AttendanceStatus {
  NORMAL // 정상
  LATE // 지각
  EARLY_LEAVE // 조퇴
  ABSENT // 결근
  LEAVE // 휴가 (is_work=false 유형)
}

/// 근무유형 (데이/이브닝/나이트/비번/연차/병가)
model ShiftType {
  id   Int    @id @default(autoincrement())
  code String @unique @db.VarChar(20) // D, E, N, OFF, ANNUAL, SICK
  name String @db.VarChar(50) // 데이, 이브닝, 나이트, 비번, 연차, 병가

  // 벽시계 시각을 문자열로 둔다. MySQL TIME 을 Prisma 가 DateTime 으로 매핑해
  // 날짜가 딸려오고 타임존 변환에 휘말리는 것을 피한다. is_work=false 면 null.
  start_time String? @db.VarChar(5) // "08:00"
  end_time   String? @db.VarChar(5) // "17:00"

  crosses_midnight Boolean @default(false) // 나이트처럼 종료가 다음날이면 true
  break_minutes    Int     @default(0) // 휴게시간 — 근무시간 계산에서 뺀다
  is_work          Boolean @default(true) // 비번·연차·병가는 false

  color String @default("#64748b") @db.VarChar(20) // 그리드 셀 색

  schedules   ShiftSchedule[]
  attendances Attendance[] // 판정 기준 스냅샷 역참조
  leaveTypes  LeaveType[]     @relation("LeaveTypeShift") // 이 근무유형으로 찍히는 휴가유형

  sort       Int      @default(0)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([sort])
}

/// 근무표 — 직원 × 날짜 = 근무유형
model ShiftSchedule {
  id          Int      @id @default(autoincrement())
  employee_id Int
  employee    Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  work_date DateTime @db.Date

  shift_type_id Int
  shift_type    ShiftType @relation(fields: [shift_type_id], references: [id])

  memo String? @db.VarChar(200)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([employee_id, work_date]) // 하루에 근무 하나
  @@index([work_date])
}

/// 실제 출퇴근 — work_date 는 시작일 기준(나이트도 마찬가지)
model Attendance {
  id          Int      @id @default(autoincrement())
  employee_id Int
  employee    Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  work_date DateTime @db.Date // 나이트 근무도 시작일

  check_in  DateTime? // null 이면 결근
  check_out DateTime? // null 이면 퇴근 미기록

  // 판정 기준 스냅샷 — 근무표가 나중에 바뀌어도 판정 근거는 남아야 한다.
  // null 이면 근무표에 없는 날 출근한 것.
  shift_type_id Int?
  shift_type    ShiftType? @relation(fields: [shift_type_id], references: [id])

  // 계산 결과를 저장한다 — 조회할 때마다 재계산하지 않는다
  status              AttendanceStatus @default(NORMAL)
  work_minutes        Int              @default(0) // 실근무 (휴게 제외)
  overtime_minutes    Int              @default(0)
  late_minutes        Int              @default(0)
  early_leave_minutes Int              @default(0)

  memo String? @db.VarChar(200)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([employee_id, work_date])
  @@index([work_date])
  @@index([status])
}

//////////////////////////////////////////////////////////////
// 휴가 · 연차
//////////////////////////////////////////////////////////////

/// 휴가 신청 상태
enum LeaveStatus {
  PENDING // 대기
  APPROVED // 승인
  REJECTED // 반려
  CANCELED // 취소
}

/// 휴가유형 마스터 (연차·병가·경조사·공가·무급)
model LeaveType {
  id   Int    @id @default(autoincrement())
  code String @unique @db.VarChar(20) // ANNUAL, SICK, EVENT, OFFICIAL, UNPAID
  name String @db.VarChar(50)

  is_paid           Boolean @default(true) // 유급 여부
  deduct_annual     Boolean @default(false) // 연차 잔여에서 차감 (연차만 true)
  requires_approval Boolean @default(true) // 승인 절차 필요 여부

  // 승인 시 근무표에 찍을 근무유형 (연차→ANNUAL, 병가→SICK 등). null 이면 근무표 미반영.
  shift_type_id Int?
  shift_type    ShiftType? @relation("LeaveTypeShift", fields: [shift_type_id], references: [id])

  color String @default("#64748b") @db.VarChar(20)

  requests LeaveRequest[]

  sort       Int      @default(0)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([sort])
}

/// 연차 부여 (직원 × 연도) — 잔여 = granted_days − 승인된 차감성 휴가일수
model LeaveGrant {
  id          Int      @id @default(autoincrement())
  employee_id Int
  employee    Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  year         Int
  granted_days Float // 부여 연차 (반차 0.5 단위)
  note         String? @db.VarChar(200)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([employee_id, year])
  @@index([year])
}

/// 휴가 신청 / 승인
model LeaveRequest {
  id          Int      @id @default(autoincrement())
  employee_id Int
  employee    Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  leave_type_id Int
  leave_type    LeaveType @relation(fields: [leave_type_id], references: [id])

  start_date DateTime @db.Date
  end_date   DateTime @db.Date
  days       Float // 신청 일수 (반차 0.5 지원)

  reason String? @db.VarChar(300)

  status LeaveStatus @default(PENDING)

  // 승인/반려 처리 이력
  approver_id   Int?
  approver      Employee? @relation("LeaveApprover", fields: [approver_id], references: [id])
  approved_at   DateTime?
  reject_reason String?   @db.VarChar(300)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([employee_id])
  @@index([status])
  @@index([start_date])
}

// ─────────────────────────────────────────────
// 재무(Finance) — 수입·지출 장부
// ─────────────────────────────────────────────

model AccountItem {
  id Int @id @default(autoincrement())

  type String  @db.VarChar(10) // INCOME | EXPENSE
  name String  @db.VarChar(100) // 표시명

  is_active Boolean @default(true)
  sort      Int     @default(0)

  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt

  transactions FinanceTransaction[] @relation("FinanceTxnAccount")
  budgets      FinanceBudget[]

  @@unique([type, name])
  @@index([type, sort])
}

model FinanceBudget {
  id Int @id @default(autoincrement())

  account_item_id Int
  account_item    AccountItem @relation(fields: [account_item_id], references: [id], onDelete: Cascade)

  year   Int
  amount Decimal @db.Decimal(15, 2) // 연간 예산(KRW)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([account_item_id, year])
  @@index([year])
}

model FinanceTransaction {
  id Int @id @default(autoincrement())

  txn_date DateTime @db.Date // 거래 일자
  type     String   @db.VarChar(10) // INCOME | EXPENSE (account.type 와 일치)

  account_item_id Int
  account_item    AccountItem @relation("FinanceTxnAccount", fields: [account_item_id], references: [id])

  amount Decimal @db.Decimal(15, 2) // KRW

  department_id Int?
  department    Department? @relation("FinanceTxnDepartment", fields: [department_id], references: [id])

  vendor String? @db.VarChar(120) // 거래처
  method String  @db.VarChar(10) // CASH | TRANSFER | CARD | OTHER
  memo   String? @db.VarChar(255)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  attachments FinanceAttachment[]

  @@index([txn_date])
  @@index([type])
  @@index([account_item_id])
  @@index([department_id])
}

model FinanceAttachment {
  id             Int                @id @default(autoincrement())
  transaction_id Int
  transaction    FinanceTransaction @relation(fields: [transaction_id], references: [id], onDelete: Cascade)

  path      String  // /uploads/finance/xxx
  filename  String  // 원본 파일명
  mime_type String?
  size      Int?
  is_image  Boolean @default(false)

  created_at DateTime @default(now())

  @@index([transaction_id])
}

// ─────────────────────────────────────────────
// 구매(Purchasing) — 거래처 · 발주
// ─────────────────────────────────────────────

model Vendor {
  id Int @id @default(autoincrement())

  name        String  @db.VarChar(120) // 상호
  business_no String? @db.VarChar(20) // 사업자번호
  contact     String? @db.VarChar(60) // 담당자
  phone       String? @db.VarChar(30)
  email       String? @db.VarChar(120)
  memo        String? @db.VarChar(255)

  is_active Boolean @default(true)
  sort      Int     @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  orders PurchaseOrder[]
  assets Asset[]

  @@index([sort])
}

model PurchaseOrder {
  id Int @id @default(autoincrement())

  vendor_id Int
  vendor    Vendor @relation(fields: [vendor_id], references: [id])

  order_date DateTime @db.Date
  status     String   @db.VarChar(12) // DRAFT | ORDERED | RECEIVED | CANCELED

  department_id Int?
  department    Department? @relation("PODepartment", fields: [department_id], references: [id])

  memo String? @db.VarChar(255)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  items PurchaseOrderItem[]

  @@index([order_date])
  @@index([status])
  @@index([vendor_id])
}

model PurchaseOrderItem {
  id       Int           @id @default(autoincrement())
  order_id Int
  order    PurchaseOrder @relation(fields: [order_id], references: [id], onDelete: Cascade)

  name       String  @db.VarChar(150) // 품목명(자유 입력)
  qty        Decimal @db.Decimal(12, 2)
  unit       String? @db.VarChar(20) // 단위(개/박스 등)
  unit_price Decimal @db.Decimal(15, 2)

  @@index([order_id])
}

// ─────────────────────────────────────────────
// 재고(Inventory) — 품목 · 입출고 수불부
// ─────────────────────────────────────────────

model Item {
  id Int @id @default(autoincrement())

  name         String  @db.VarChar(150) // 품목명
  category     String? @db.VarChar(60) // 분류(자유 입력)
  unit         String? @db.VarChar(20) // 단위(개/박스 등)
  safety_stock Decimal @default(0) @db.Decimal(12, 2) // 안전재고

  is_active Boolean @default(true)
  sort      Int     @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  movements StockMovement[]

  @@index([sort])
}

model StockMovement {
  id Int @id @default(autoincrement())

  item_id Int
  item    Item @relation(fields: [item_id], references: [id], onDelete: Cascade)

  type String  @db.VarChar(10) // IN | OUT | ADJUST
  qty  Decimal @db.Decimal(12, 2) // 부호 있는 증감 (입고 +, 출고 -, 조정 ±)

  moved_at DateTime @db.Date

  department_id Int?
  department    Department? @relation("StockMoveDepartment", fields: [department_id], references: [id])

  memo String? @db.VarChar(255)

  created_at DateTime @default(now())

  @@index([item_id])
  @@index([moved_at])
  @@index([type])
}

// ─────────────────────────────────────────────
// 자산(Assets) — 자산 대장
// ─────────────────────────────────────────────

model Asset {
  id Int @id @default(autoincrement())

  asset_no String? @db.VarChar(40) // 자산번호
  name     String  @db.VarChar(150) // 자산명
  category String? @db.VarChar(60) // 분류(의료장비/IT/가구 등)

  acquired_at  DateTime? @db.Date // 취득일
  acquire_cost Decimal   @default(0) @db.Decimal(15, 2) // 취득가

  status String @db.VarChar(12) // ACTIVE | REPAIR | IDLE | DISPOSED

  department_id Int?
  department    Department? @relation("AssetDepartment", fields: [department_id], references: [id])

  vendor_id Int?
  vendor    Vendor? @relation(fields: [vendor_id], references: [id]) // 구매처

  memo String? @db.VarChar(255)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([status])
  @@index([department_id])
  @@index([acquired_at])
}

// ─────────────────────────────────────────────
// 시설(Facility) — 유지보수 요청
// ─────────────────────────────────────────────

model FacilityRequest {
  id Int @id @default(autoincrement())

  title    String  @db.VarChar(150) // 요청 제목
  location String? @db.VarChar(120) // 위치
  category String? @db.VarChar(60) // 분류(전기/배관/HVAC 등)

  priority String @db.VarChar(10) // LOW | NORMAL | HIGH | URGENT
  status   String @db.VarChar(12) // RECEIVED | IN_PROGRESS | DONE | CANCELED

  reported_at DateTime  @db.Date // 요청일
  resolved_at DateTime? @db.Date // 완료일

  department_id Int?
  department    Department? @relation("FacilityDepartment", fields: [department_id], references: [id])

  assignee   String? @db.VarChar(60) // 담당자(자유 입력)
  content    String? @db.VarChar(500) // 요청 내용
  resolution String? @db.VarChar(500) // 처리 내용

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([status])
  @@index([reported_at])
  @@index([department_id])
}

// ─────────────────────────────────────────────
// 예약(Reservation) — 진료 예약
// ─────────────────────────────────────────────

model Appointment {
  id Int @id @default(autoincrement())

  patient_name  String  @db.VarChar(60) // 환자명(자유 입력)
  patient_phone String? @db.VarChar(30)

  department_id Int?
  department    Department? @relation("AppointmentDept", fields: [department_id], references: [id])

  doctor_id Int?
  doctor    Employee? @relation("AppointmentDoctor", fields: [doctor_id], references: [id])

  reserved_at DateTime // 예약 일시 (날짜+시간)
  status      String   @db.VarChar(12) // BOOKED | VISITED | NOSHOW | CANCELED

  memo String? @db.VarChar(255)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([reserved_at])
  @@index([status])
  @@index([department_id])
}
